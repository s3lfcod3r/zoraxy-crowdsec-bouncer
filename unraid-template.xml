<?xml version="1.0"?>
<Container version="2">
  <Name>zoraxy-crowdsec-bouncer</Name>
  <Repository>ghcr.io/kabelsalatundklartext/zoraxy-crowdsec-bouncer:latest</Repository>
  <Registry>https://github.com/kabelsalatundklartext/zoraxy-crowdsec-bouncer/pkgs/container/zoraxy-crowdsec-bouncer</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/kabelsalatundklartext/zoraxy-crowdsec-bouncer</Support>
  <Project>https://github.com/kabelsalatundklartext/zoraxy-crowdsec-bouncer</Project>
  <Overview>
    Zoraxy reverse proxy with the CrowdSec Bouncer plugin pre-installed.
    The config.yaml is created automatically on first start using the variables below.

    Credits:
    - Zoraxy by tobychui (AGPL v3): https://github.com/tobychui/zoraxy
    - zoraxy_crowdsec_bouncer by AnthonyMichaelTDM (MIT): https://github.com/AnthonyMichaelTDM/zoraxy_crowdsec_bouncer
  </Overview>
  <Category>Network:Proxy</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/kabelsalatundklartext/zoraxy-crowdsec-bouncer/main/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/tobychui/zoraxy/main/web/img/logo.png</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <Description>Zoraxy with CrowdSec Bouncer plugin. config.yaml is auto-created from the variables below.</Description>

  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>8000</HostPort>
        <ContainerPort>8000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>

  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/zoraxy/config</HostDir>
      <ContainerDir>/opt/zoraxy/config/</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/zoraxy/plugin</HostDir>
      <ContainerDir>/opt/zoraxy/plugin/</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/var/run/docker.sock</HostDir>
      <ContainerDir>/var/run/docker.sock</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
    <Volume>
      <HostDir>/etc/localtime</HostDir>
      <ContainerDir>/etc/localtime</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
  </Data>

  <Environment>
    <Variable>
      <Value></Value>
      <Name>CROWDSEC_API_KEY</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>http://crowdsec:8080</Value>
      <Name>CROWDSEC_AGENT_URL</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>warning</Value>
      <Name>CROWDSEC_LOG_LEVEL</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>false</Value>
      <Name>CROWDSEC_CLOUDFLARE</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>true</Value>
      <Name>FASTGEOIP</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>true</Value>
      <Name>DOCKER</Name>
      <Mode/>
    </Variable>
  </Environment>

  <!-- Ports -->
  <Config Name="WebUI Port" Target="8000" Default="8000" Mode="tcp"
    Description="Zoraxy Management WebUI"
    Type="Port" Display="always" Required="true" Mask="false">8000</Config>

  <Config Name="HTTP Port" Target="80" Default="80" Mode="tcp"
    Description="HTTP traffic"
    Type="Port" Display="always" Required="true" Mask="false">80</Config>

  <Config Name="HTTPS Port" Target="443" Default="443" Mode="tcp"
    Description="HTTPS traffic"
    Type="Port" Display="always" Required="true" Mask="false">443</Config>

  <!-- Pfade -->
  <Config Name="Config Folder" Target="/opt/zoraxy/config/" Default="/mnt/user/appdata/zoraxy/config" Mode="rw"
    Description="Zoraxy Konfiguration, Zertifikate und Logs"
    Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/zoraxy/config</Config>

  <Config Name="Plugin Folder" Target="/opt/zoraxy/plugin/" Default="/mnt/user/appdata/zoraxy/plugin" Mode="rw"
    Description="Plugin-Daten inkl. automatisch erstellter config.yaml"
    Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/zoraxy/plugin</Config>

  <!-- CrowdSec Variablen -->
  <Config Name="CrowdSec API Key" Target="CROWDSEC_API_KEY" Default="" Mode=""
    Description="API Key von CrowdSec. Befehl: docker exec -it crowdsec cscli bouncers add zoraxy-bouncer"
    Type="Variable" Display="always" Required="true" Mask="true"></Config>

  <Config Name="CrowdSec Agent URL" Target="CROWDSEC_AGENT_URL" Default="http://crowdsec:8080" Mode=""
    Description="URL deiner CrowdSec Instanz. Beispiel: http://192.168.1.100:8080"
    Type="Variable" Display="always" Required="true" Mask="false">http://crowdsec:8080</Config>

  <Config Name="Log Level" Target="CROWDSEC_LOG_LEVEL" Default="warning" Mode=""
    Description="Log-Level des Bouncers: trace / debug / info / warning / error"
    Type="Variable" Display="advanced" Required="false" Mask="false">warning</Config>

  <Config Name="Cloudflare Proxy" Target="CROWDSEC_CLOUDFLARE" Default="false" Mode=""
    Description="Auf true setzen wenn Zoraxy hinter Cloudflare läuft"
    Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>

  <!-- Zoraxy Einstellungen -->
  <Config Name="Fast GeoIP" Target="FASTGEOIP" Default="true" Mode=""
    Description="Schnelle GeoIP-Datenbank aktivieren"
    Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>

  <Config Name="Docker Mode" Target="DOCKER" Default="true" Mode=""
    Description="Docker-Kompatibilitätsmodus"
    Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>

</Container>
